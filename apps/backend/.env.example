DATABASE_URL="postgresql://user:password@localhost:5432/netservice_connect"
JWT_SECRET="change-me-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

META_APP_ID="your_meta_app_id"
META_APP_SECRET="your_meta_app_secret"
META_VERIFY_TOKEN="your_global_webhook_verify_token"
META_API_VERSION="v19.0"

OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

PORT=3001
FRONTEND_URL="http://localhost:3000"

# Opcional: ruta donde se guardan los archivos multimedia de WhatsApp (separados por
# carpeta de tenant adentro). Si no se define, usa ./media junto al backend.
# Se puede sobreescribir sin tocar esta variable desde Settings > Sistema (queda en DB
# y tiene prioridad sobre esto) — util para no tener que redeployar al mover de server.
# MEDIA_STORAGE_PATH="D:\NetServiceMedia"
