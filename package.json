{
  "name": "netservice-connect",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "backend": "npm run start:dev --workspace=apps/backend",
    "frontend": "npm run dev --workspace=apps/frontend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "db:generate": "npm run prisma:generate --workspace=apps/backend",
    "db:migrate": "npm run prisma:migrate --workspace=apps/backend",
    "db:push": "npm run prisma:push --workspace=apps/backend",
    "db:studio": "npm run prisma:studio --workspace=apps/backend",
    "db:seed": "npm run prisma:seed --workspace=apps/backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
